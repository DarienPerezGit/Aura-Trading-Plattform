# ============================================================
# Aura Trading Platform — Environment Variables
# Copy this file to .env and fill in your keys
# cp example.env .env
# ============================================================

# ----------------------------------------------------------
# Anthropic  (CRITICAL — required for AI agents to run)
# https://console.anthropic.com/settings/keys
# ----------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ----------------------------------------------------------
# Finnhub  (real-time market data + news feed)
# https://finnhub.io/register
# ----------------------------------------------------------
FINNHUB_API_KEY=your_finnhub_api_key_here

# ----------------------------------------------------------
# Alpaca  (US stock execution & market data)
# https://app.alpaca.markets/signup
# Set to "paper" for paper trading, "live" for real trading
# ----------------------------------------------------------
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ----------------------------------------------------------
# FRED  (Federal Reserve macro-economic data)
# https://fred.stlouisfed.org/docs/api/api_key.html
# ----------------------------------------------------------
FRED_API_KEY=your_fred_api_key_here

# ----------------------------------------------------------
# Polygon.io  (order book data — optional, can start without)
# https://polygon.io/dashboard/signup
# ----------------------------------------------------------
POLYGON_API_KEY=your_polygon_api_key_here
